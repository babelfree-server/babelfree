  "games": [
    {
      "type": "skit",
      "label": "Escena",
      "title": "Un día de compras",
      "grammar": [
        "imperativo (tú)",
        "por/para"
      ],
      "instruction": "Escucha la conversación en el mercado.",
      "beats": [
        {
          "speaker": "candelaria",
          "text": "Primero vamos al supermercado. Necesitamos arroz, leche y verduras."
        },
        {
          "speaker": "yaguara",
          "text": "¿Y dónde está el supermercado?"
        },
        {
          "speaker": "candelaria",
          "text": "Está al final de la calle, a la derecha. Mira, ahí está la parada del autobús."
        },
        {
          "speaker": "narrator",
          "text": "En el supermercado hay muchas cosas. Candelaria toma un carrito."
        },
        {
          "speaker": "candelaria",
          "text": "El arroz cuesta tres mil pesos. La leche cuesta cuatro mil. ¿Cuánto es en total?"
        },
        {
          "speaker": "yaguara",
          "text": "Siete mil pesos. Tenemos suficiente dinero."
        },
        {
          "speaker": "narrator",
          "text": "Después del supermercado, van a la farmacia. Candelaria compra medicina para su abuela."
        },
        {
          "speaker": "candelaria",
          "text": "Mi abuela necesita esta medicina. Cuesta diez mil pesos."
        },
        {
          "speaker": "narrator",
          "text": "Pagan en efectivo. El vendedor les da el cambio y un recibo."
        },
        {
          "speaker": "yaguara",
          "text": "En el bosque no hay dinero. Pero aquí, el dinero es como un idioma más."
        }
      ]
    },
    {
      "type": "narrative",
      "label": "Narrativa",
      "title": "El pueblo de Candelaria",
      "text": "El pueblo de Candelaria tiene una plaza central. En la plaza hay una iglesia vieja, un banco con cajero automático, una farmacia verde y un supermercado grande. Hay una estación de autobuses donde salen buses para la ciudad. Al lado de la estación hay una biblioteca pequeña. Los niños van a la escuela por la mañana y al mercado con sus mamás por la tarde. Los vendedores gritan los precios: «¡Plátano a mil! ¡Pescado fresco! ¡Frutas del valle!» El mercado es ruidoso, colorido y vivo."
    },
    {
      "type": "narrative",
      "label": "Narrativa",
      "title": "Carrasquilla — Las calles del pueblo",
      "text": "Carrasquilla escribió sobre los pueblos de Antioquia. En sus historias, las calles tienen vida propia. Los vecinos se saludan, los vendedores gritan, los niños corren. En el pueblo de Carrasquilla, comprar pan es un acto social. Ir al banco es una excursión. Y la farmacia es donde la gente cuenta sus dolores — no solo los del cuerpo."
    },
