    "title": "El mercado y la calle",
    "instruction": "Escucha la historia.",
    "beats": [
      {
        "speaker": "narrator",
        "text": "El pueblo tiene una calle principal. Hay tiendas, una farmacia, un banco y un mercado grande."
      },
      {
        "speaker": "candelaria",
        "text": "Yaguará, hoy vamos al mercado. Necesitamos comprar muchas cosas."
      },
      {
        "speaker": "yaguara",
        "text": "¿Qué es comprar? En el bosque no compramos nada."
      },
      {
        "speaker": "candelaria",
        "text": "Comprar es dar dinero y recibir algo. Ven, te enseño."
      }
    ]
  },
  "departure": {
    "closingQuestion": "Candelaria guarda las compras en su bolsa. El mercado cierra.",
    "yaguaraLine": "El pueblo tiene nombres diferentes. Tienda, farmacia, banco. Son nombres que la gente necesita para vivir juntos.",
    "button": "Continuar el viaje"
