  "arrival": {
    "beats": [
      {
        "speaker": "narrator",
        "text": "Un pueblo industrial al borde del río. Chimeneas, talleres, el sonido de máquinas que no descansan."
      },
      {
        "speaker": "narrator",
        "text": "Hay hombres con cascos amarillos. Hay mujeres con carpetas llenas de números. Todos caminan rápido."
      },
      {
        "speaker": "candelaria",
        "text": "Aquí la gente trabaja desde que sale el sol. Mi tía tenía una oficina en este pueblo."
      },
      {
        "speaker": "yaguara",
        "text": "En el bosque no había oficinas. Los árboles no necesitan contratos."
      },
      {
        "speaker": "narrator",
        "text": "Don Próspero aparece con un portafolio de cuero. Sonríe como siempre. Ofrece trabajo a todos."
      }
    ],
    "type": "skit",
    "label": "Llegada",
    "title": "El trabajo de las manos",
    "instruction": "Escucha la historia."
  },
  "departure": {
    "closingQuestion": "¿Qué significa trabajar para alguien que no conoces?",
    "yaguaraLine": "Cada oficio tiene su propio idioma. El pescador no habla como el banquero.",
    "button": "Continuar el viaje"
  },
