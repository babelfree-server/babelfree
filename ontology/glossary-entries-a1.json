[
  {
    "id": "lt_verb_ser_indicative_present",
    "lemma": "ser",
    "pos": "verb",
    "cefr": "A1",
    "definitions": [
      {
        "text": "indicar identidad, origen o características permanentes",
        "source": "RAE"
      }
    ],
    "examples": [
      {
        "sentence": "Yo soy colombiana.",
        "translations": {
          "en": "I am Colombian.",
          "pt": "Eu sou colombiana.",
          "fr": "Je suis colombienne."
        }
      },
      {
        "sentence": "El jaguar es fuerte.",
        "translations": {
          "en": "The jaguar is strong.",
          "pt": "O jaguar é forte.",
          "fr": "Le jaguar est fort."
        }
      }
    ],
    "translations": {
      "en": "to be (identity)",
      "pt": "ser",
      "fr": "être (identité)"
    },
    "forms": {
      "present": {
        "yo": "soy",
        "tú": "eres",
        "él/ella/usted": "es",
        "nosotros": "somos",
        "ellos/ellas/ustedes": "son"
      }
    },
    "notes": "Irregular. Used for identity, origin, profession, and permanent qualities. Contrast with estar."
  },
