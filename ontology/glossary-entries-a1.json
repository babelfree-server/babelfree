  {
    "id": "lt_verb_haber_impersonal",
    "lemma": "haber",
    "pos": "verb",
    "cefr": "A1",
    "definitions": [
      {
        "text": "indicar existencia de algo",
        "source": "RAE"
      }
    ],
    "examples": [
      {
        "sentence": "Hay un jaguar en el bosque.",
        "translations": {
          "en": "There is a jaguar in the forest.",
          "pt": "Há um jaguar no bosque.",
          "fr": "Il y a un jaguar dans la forêt."
        }
      },
      {
        "sentence": "Hay muchos árboles aquí.",
        "translations": {
          "en": "There are many trees here.",
          "pt": "Há muitas árvores aqui.",
          "fr": "Il y a beaucoup d'arbres ici."
        }
      }
    ],
    "translations": {
      "en": "there is / there are",
      "pt": "haver (há)",
      "fr": "il y a"
    },
    "forms": {
      "present": {
        "impersonal": "hay"
      }
    },
    "notes": "At A1 only the impersonal form 'hay' (there is/are) is used. Invariable — same form for singular and plural."
  },
