          "fr": "Je m'appelle Yaguará."
        }
      },
      {
        "sentence": "Mi hermana se llama Ana.",
        "translations": {
          "en": "My sister's name is Ana.",
          "pt": "Minha irmã se chama Ana.",
          "fr": "Ma sœur s'appelle Ana."
        }
      }
    ],
    "translations": {
      "en": "to be called",
      "pt": "chamar-se",
      "fr": "s'appeler"
    },
    "forms": {
